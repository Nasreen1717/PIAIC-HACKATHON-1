## 6. Advanced Topics & Extensions

### 6.1 Terrain-Aware Navigation

Bipedal robots can navigate on different terrain types with adapted parameters:

**Terrain Cost Model**:

| Terrain | Friction | Stability | Stride Reduction | Energy Cost |
|---------|----------|-----------|------------------|-------------|
| Carpet | 0.5 | 0.8 | -10% | +15% |
| Concrete | 0.7 | 1.0 | 0% | 0% |
| Vinyl (slippery) | 0.3 | 0.6 | -20% | +25% |
| Gravel | 0.4 | 0.7 | -15% | +30% |
| Grass | 0.6 | 0.8 | -10% | +20% |
| Sand | 0.2 | 0.5 | -30% | +50% |
| Stairs (up) | 0.8 | 0.6 | -25% | +100% |
| Stairs (down) | 0.8 | 0.5 | -30% | +60% |

**Terrain Classifier Node**:

```python
class TerrainClassifier(Node):
    """Classify ground terrain from IMU and pressure sensors."""

    def __init__(self):
        super().__init__('terrain_classifier')

        # Sensors
        self.imu_sub = self.create_subscription(Imu, '/imu/data', self.imu_callback, 10)
        self.pressure_sub = self.create_subscription(
            Float32MultiArray, '/pressure_sensors/feet', self.pressure_callback, 10
        )

        # Classifier model
        self.terrain_pub = self.create_publisher(String, '/terrain/type', 10)

    def classify_from_vibration(self, imu_accel: np.ndarray) -> str:
        """Classify terrain from vibration signature."""
        # Compute FFT of acceleration
        fft = np.abs(np.fft.fft(imu_accel))
        freqs = np.fft.fftfreq(len(imu_accel), 0.01)

        # Grass: high frequency content (>50 Hz)
        # Carpet: medium frequency (20-50 Hz)
        # Concrete: low frequency (<20 Hz)
        # Gravel: broad frequency spectrum

        dominant_freq = freqs[np.argmax(fft)]
        energy_ratio = fft[:50].sum() / fft.sum()

        if dominant_freq > 50:
            return 'grass'
        elif dominant_freq > 20:
            return 'carpet'
        elif energy_ratio < 0.3:
            return 'gravel'
        else:
            return 'concrete'

    def classify_from_pressure(self, pressure_left: float,
                              pressure_right: float) -> str:
        """Classify from foot pressure distribution."""
        diff = abs(pressure_left - pressure_right)

        if diff > 20:  # Uneven pressure
            return 'gravel'
        elif pressure_left < 5 or pressure_right < 5:
            return 'sand'  # Sinking
        else:
            return 'concrete'
```

### 6.2 Multi-Floor Navigation

**Handling elevators and stairs:**

```python
class ElevatorNavigator(Node):
    """Navigate to and use elevators."""

    def __init__(self):
        super().__init__('elevator_navigator')
        self.in_elevator = False
        self.target_floor = 0

    def navigate_to_elevator(self, floor: int):
        """Navigate to nearest elevator for target floor."""
        # Use map with elevator locations
        elevator = self.find_nearest_elevator(floor)
        self.navigate_to_waypoint(elevator)

    def enter_elevator(self):
        """Open door and enter elevator."""
        # 1. Request elevator
        self.call_elevator_button()

        # 2. Wait for door to open (timeout 30s)
        if not self.wait_for_door_open(timeout=30):
            self.request_human_assistance()
            return False

        # 3. Walk into elevator
        self.walk_forward(distance=1.0)

        # 4. Face door
        self.face_direction(180)  # Face outward

        self.in_elevator = True
        return True

    def exit_elevator(self):
        """Exit elevator when door opens."""
        self.walk_forward(distance=1.0)
        self.in_elevator = False
        return True

    def navigate_stairs(self, direction: str = 'up', count: int = 1):
        """Navigate stairs (simplified for bipeds)."""
        for stair in range(count):
            if direction == 'up':
                # Place feet on each stair, powered by legs
                self.step_height = 0.18  # Typical step height
                self.step_stride = 0.25
            else:
                # Descend carefully (slower)
                self.step_height = 0.18
                self.step_stride = 0.15  # Shorter steps going down
                self.balance_margin *= 2  # More conservative

            self.execute_stair_step()
```

### 6.3 Failure Recovery & Resilience

**Recovery behaviors when things go wrong:**

```python
class RobustNavigationController:
    """Navigate reliably despite partial failures."""

    def __init__(self):
        self.localization_lost_count = 0
        self.max_relocalizations = 3
        self.sensor_failure_mode = None

    def handle_localization_loss(self):
        """Recover from VSLAM tracking loss."""
        self.get_logger().warn("Localization lost!")

        # Stage 1: Rotate to find features (30 seconds)
        if not self.rotate_and_relocalize(timeout=30):
            # Stage 2: Move to feature-rich area
            self.navigate_to_landmark()
            if not self.rotate_and_relocalize(timeout=30):
                # Stage 3: Request assistance
                self.request_human_help("Cannot relocalize VSLAM")
                return False

        return True

    def handle_sensor_failure(self, sensor: str):
        """Gracefully handle sensor loss."""
        self.sensor_failure_mode = sensor
        self.get_logger().error(f"Sensor {sensor} failed!")

        if sensor == 'camera':
            # Fall back to LiDAR odometry
            self.max_speed *= 0.5
            self.use_lidar_only_navigation()

        elif sensor == 'lidar':
            # Use contact sensors + IMU
            self.max_speed *= 0.3
            self.use_haptic_navigation()

        elif sensor == 'imu':
            # Degrade balance safety
            self.balance_margin *= 2
            self.max_slope = 0.05  # Conservative

        elif sensor == 'motor':
            # Limp to safety
            self.goto_safe_location()

        return True

    def compensate_for_missing_sensor(self, sensor: str):
        """Adjust planning when sensor is unavailable."""
        if sensor == 'camera':
            # Increase costmap inflation (less precise obstacle detection)
            self.costmap.inflation_radius = 0.3
            # More frequent sensor scans needed
            self.lidar_frequency = 20  # Hz

        elif sensor == 'lidar':
            # Reduce speed to give camera more reaction time
            self.max_forward_speed = 0.3
            # Rely on depth camera
            self.depth_frequency = 30  # Hz

    def estimate_navigation_confidence(self) -> float:
        """Rate confidence in current navigation (0-1)."""
        confidence = 1.0

        # Localization quality
        if self.localization_uncertainty > 0.2:
            confidence *= 0.7

        # Sensor health
        for sensor, is_healthy in self.sensor_status.items():
            if not is_healthy:
                confidence *= 0.8

        # Recent failures
        confidence *= 0.95 ** self.localization_lost_count

        return confidence
```

### 6.4 Performance Optimization

**Achieving real-time navigation at scale:**

```python
def optimize_nav2_performance():
    """Configuration for real-time performance."""
    return {
        'global_costmap': {
            'plugins': ['static_layer', 'inflation_layer'],  # Minimal layers
            'update_frequency': 5.0,  # 5 Hz (not 10 Hz)
            'publish_frequency': 2.0,  # Lazy publishing
            'footprint_padding': 0.05,  # Minimal inflation radius
            'inflation_radius': 0.20,  # Humanoid-specific
        },

        'local_costmap': {
            'plugins': ['obstacle_layer', 'inflation_layer'],
            'update_frequency': 10.0,  # Higher local frequency
            'obstacle_layer': {
                'max_obstacle_height': 2.0,
                'min_obstacle_height': 0.05,
            },
        },

        'global_planner': {
            'allow_unknown': False,
            'max_iterations': 500000,  # Reasonable limit
            'max_planning_time': 2.0,  # 2 second timeout
            'analytic_expansion_ratio': 3.5,  # Fast expansion heuristic
        },

        'local_controller': {
            'sim_time': 1.5,  # Look ahead 1.5 seconds
            'linear_granularity': 0.05,
            'angular_granularity': 0.025,
            'vx_samples': 20,  # Fewer samples = faster
            'vtheta_samples': 20,
        },

        'recovery_behaviors': [],  # Disable or minimize
    }
```

### 6.5 Integration with Vision-Language Models

**Preparing for Module 4 (Vision-Language Actions):**

```python
class VisionLanguageIntegration(Node):
    """Bridge Nav2 navigation with vision-language instructions."""

    def __init__(self):
        super().__init__('vision_language_bridge')

        # Publisher for high-level goals
        self.goal_pub = self.create_publisher(GoalMsg, '/goal', 10)

        # Subscriber for natural language commands
        self.language_sub = self.create_subscription(
            String,
            '/instruction',
            self.instruction_callback,
            10
        )

    def instruction_callback(self, msg: String):
        """Convert natural language to navigation goal."""
        instruction = msg.data

        # Examples:
        # "Go to the conference room" → navigate to known location
        # "Find a person wearing a red shirt" → search behavior
        # "Follow that person" → tracking behavior
        # "Go upstairs" → multi-floor navigation

        if 'go to' in instruction.lower():
            location = self.parse_location(instruction)
            self.navigate_to_location(location)

        elif 'find' in instruction.lower():
            target = self.parse_target(instruction)
            self.search_and_find(target)

        elif 'follow' in instruction.lower():
            person = self.identify_person(instruction)
            self.follow_person(person)
```

