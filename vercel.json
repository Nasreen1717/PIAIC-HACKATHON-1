{
  "version": 2,
  "buildCommand": "npm run build --prefix Front-End-Book",
  "outputDirectory": "Front-End-Book/build",
  "installCommand": "npm install --prefix Front-End-Book && pip install --target ./api/lib -r ./api/requirements.txt",
  "env": {
    "REACT_APP_API_URL": "/api",
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "OPENAI_API_KEY": "@openai_api_key",
    "FRONTEND_URL": "@frontend_url"
  },
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(?P<path>.*)",
      "dest": "/api/$path.py"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
