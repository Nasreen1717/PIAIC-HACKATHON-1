  !important; padding: 0 var(--spacing-3xl) !important; /* 0 48px */ max-width: 100%; margin: 0; width: 100%; 
  box-sizing: border-box; height: 64px; gap: var(--spacing-lg); /* 24px between sections */
}

/* Logo Section (Left) */ .navbar__brand { .navbar__logo img { display: flex !important; height: 100% 
  !important; align-items: center !important; justify-content: flex-start !important; min-width: 0 !important; 
  flex-shrink: 1 !important; margin: 0 !important; padding: 0 var(--spacing-sm) !important; /* 0 8px - minimal 
  padding */ height: 64px; max-width: 80px; overflow: hidden; width: auto !important;} max-height: 48px 
  !important;
