# Frontend Production Environment Variables
# These are built into the frontend bundle at build time

# API Base URL - routes all API calls through Vercel serverless functions
REACT_APP_API_URL=/api

# Feature Flags
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_TRANSLATION=true
REACT_APP_ENABLE_PERSONALIZATION=true

# UI Settings
REACT_APP_SITE_NAME=ThinkMesh
REACT_APP_THEME_MODE=auto
