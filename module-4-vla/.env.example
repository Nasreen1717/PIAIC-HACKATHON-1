# Module 4 VLA Capstone - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# Optional: OpenAI Organization ID (if using organization account)
# Get from: https://platform.openai.com/account/org-settings/organization-id
OPENAI_ORG_ID=org-YOUR_ORG_ID_HERE

# ROS 2 Configuration
# Domain ID for ROS 2 (prevents conflicts on shared networks)
# Default: 0, must be unique on same network
ROS_DOMAIN_ID=1

# Isaac Sim Configuration
# Path to Isaac Sim installation (if not in standard location)
# ISAAC_SIM_PATH=/opt/nvidia/isaac-sim

# Whisper Configuration
# Model size: base (default), small, medium, large
WHISPER_MODEL=base

# Audio Input Device ID (default: system microphone)
# List available: python -m sounddevice
# AUDIO_DEVICE_ID=0

# Logging Configuration
# Log level: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO

# Logging Output
# log_file_path for saving logs (optional)
# LOG_FILE_PATH=./logs/module4.log

# Testing Configuration
# Isaac Sim headless mode for CI/testing
ISAAC_SIM_HEADLESS=false

# Cost Control (optional)
# Max API cost per session in USD (prevents runaway costs)
# MAX_API_COST_USD=10.0

# Feature Flags (for development)
# Enable experimental features
# ENABLE_EXPERIMENTAL=false

# Debug Mode
# Verbose logging and additional diagnostics
DEBUG_MODE=false

# Notes:
# 1. OPENAI_API_KEY is REQUIRED for voice and planning features
# 2. Keep .env file secure - never commit to git
# 3. For CI/CD, set environment variables directly in pipeline
# 4. On shared machines, use unique ROS_DOMAIN_IDs to avoid interference
# 5. See quickstart.md for detailed setup instructions
