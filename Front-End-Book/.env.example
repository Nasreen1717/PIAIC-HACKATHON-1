# T077: Environment Configuration Template
# Copy this file to .env.local and adjust values for your environment

# Backend API URL
# Default: http://localhost:8000
REACT_APP_API_URL=http://localhost:8000

# Enable/disable chatbot
# Default: true
REACT_APP_CHATBOT_ENABLED=true

# OpenAI API Key (REQUIRED for translation feature)
# Get your API key from: https://platform.openai.com/api-keys
REACT_APP_OPENAI_API_KEY=sk-proj-your-api-key-here

# Optional: Maximum message length (characters)
# Default: 2000
REACT_APP_MAX_MESSAGE_LENGTH=2000

# Optional: API timeout (milliseconds)
# Default: 3000
REACT_APP_API_TIMEOUT=3000
