{
  "name": "thinkmesh-deployment",
  "version": 2,
  "buildCommand": "npm run build --prefix Front-End-Book",
  "outputDirectory": "Front-End-Book/build",
  "installCommand": "npm install --prefix Front-End-Book && pip install --target ./api/lib -r ./api/requirements.txt",
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "OPENAI_API_KEY": "@openai_api_key",
    "FRONTEND_URL": "@frontend_url",
    "REACT_APP_API_URL": "/api"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(?!api).*",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
